[Unit]
Description=Bees BTRFS deduplication setup
Documentation=https://github.com/Zygo/bees
# /etc is mounted by dracut pre-pivot hook before systemd starts — no etc.mount
# unit exists. Bees needs only the Btrfs filesystem, so local-fs.target suffices.
After=local-fs.target

[Service]
Type=oneshot
RemainAfterExit=yes
ExecStart=/usr/local/bin/beesd-setup

[Install]
WantedBy=multi-user.target
